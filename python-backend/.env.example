# Environment Configuration
ENVIRONMENT=development
DEBUG=true

# Jarvis Local AI (your local Ollama-backed assistant)
# Run: python api/run.py inside the jarvis/ project folder first.
# Android emulator uses 10.0.2.2 to reach the host machine.
JARVIS_URL=http://localhost:7700
JARVIS_TIMEOUT_SECONDS=25

# API Keys
MASSIVE_API_KEY=your_massive_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
FINNHUB_API_KEY=your_finnhub_key_here

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# API Rate Limits (requests per minute)
ALPHA_VANTAGE_RATE_LIMIT=5
FINNHUB_RATE_LIMIT=60

# Cache Settings (seconds)
CACHE_TTL_SECONDS=300
QUOTE_CACHE_TTL=60
CANDLE_CACHE_TTL=300

# CORS Origins (comma-separated)
CORS_ORIGINS=*

# Default Watchlist (comma-separated symbols)
DEFAULT_WATCHLIST=AAPL,GOOGL,MSFT,AMZN,TSLA,NVDA,META,BTC-USD,ETH-USD

# Indicator Settings
RSI_PERIOD=14
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9
BOLLINGER_PERIOD=20
BOLLINGER_STD=2

# Valuation Settings
RISK_FREE_RATE=0.045
MARKET_RISK_PREMIUM=0.08

# ── Analyst Cycle Upgrade ─────────────────────────────────────────────────────

# PostgreSQL + pgvector (for LlamaIndex RAG)
POSTGRES_PASSWORD=changeme_strong_password

# Cartesia TTS — get key at: https://cartesia.ai
# Get your voice ID from the Cartesia playground
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=your_voice_id_here

# Deepgram STT — get key at: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Ollama base URL (override if Ollama runs outside Docker)
OLLAMA_BASE_URL=http://ollama:11434

# Analyst Graph Settings
ANALYST_DEEPSEEK_MODEL=deepseek-r1:14b
ANALYST_INTENT_MODEL=mistral
ANALYST_EMBED_MODEL=nomic-embed-text
ANALYST_MAX_REASONING_TOKENS=1500
ANALYST_VERIFICATION_THRESHOLD=0.75
ANALYST_MAX_RETRIES=2
